# ============================================================
# BACKEND SELECTION
#   LOCAL → simulator (statevector or aer)
#   IBM   → real IBM Quantum QPU via qiskit-ibm-runtime
# ============================================================
#BACKEND=LOCAL
BACKEND=IBM
# --- LOCAL simulator options (used when BACKEND=LOCAL) ---
SIMULATOR_METHOD=statevector
SHOTS=1024

# --- Transpilation (ISA) ---
OPTIMIZATION_LEVEL=1

# --- Dataset ---
RANDOM_SEED=42
TRAIN_SPLIT=0.8

# --- Circuit hyperparameters ---
NUM_QUBITS=2
FEATURE_MAP=ZZFeatureMap
FEATURE_MAP_REPS=1
ANSATZ=RealAmplitudes
ANSATZ_REPS=1
OPTIMIZER=COBYLA
MAX_ITER=50

# Run QkNN as a REAL quantum-fidelity circuit (slow on hardware) instead of the
# classical Gaussian proxy. Keep false unless you specifically need it.
QKNN_QUANTUM=false

# ============================================================
# IBM QUANTUM (new IBM Quantum Platform)
# ============================================================
IBM_API_TOKEN=<INPUT_TOKEN>
IBM_CHANNEL=ibm_quantum_platform
# Leave IBM_INSTANCE empty on the new platform (old "ibm-q/open/main" is invalid).
IBM_INSTANCE=open-instance
# A specific QPU, or "least_busy" to auto-pick the least-busy real device.
IBM_BACKEND_NAME=least_busy
# Auto-retry a failed IBM job N times (transient hardware errors are common).
IBM_MAX_RETRIES=2
# Run LOCALLY on Aer using the REAL device's noise model + coupling map.
# Hardware-representative, reproducible, NO remote job failures / QPU cost.
# Recommended if live-hardware jobs keep failing or queueing. true/false.
IBM_NOISE_SIM=false
#IBM_BACKEND_NAME=ibm_fez
#IBM_BACKEND_NAME=ibm_marrakesh
#IBM_BACKEND_NAME=ibm_kingston

# ============================================================
# HARDWARE SAFETY GUARD
#   Real QPUs are slow + metered. When a real QPU is detected we subsample the
#   data and cap iterations so a demo run stays feasible. Set HW_GUARD=false to
#   run the full dataset (expect long queues and significant QPU-time usage).
# ============================================================
HW_GUARD=true
HW_MAX_TRAIN=12
HW_MAX_TEST=6
HW_MAX_ITER=8

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=quantum_run.log

# --- Output ---
OUTPUT_DIR=outputs
VERBOSE=true
